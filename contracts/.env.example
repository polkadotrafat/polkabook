# Required for any signed deployment on testnet.
PRIVATE_KEY=0xyour_private_key_here

# Optional. Defaults to the public Polkadot Hub Paseo EVM RPC in hardhat.config.ts.
TESTNET_RPC_URL=https://services.polkadothub-rpc.com/testnet/

# Optional but recommended for Revive / PolkaVM deployment flows.
POLKADOT_RPC_URL=wss://asset-hub-paseo-rpc.n.dwellir.com

# Optional. Used only for local node deployments.
LOCALNODE_RPC_URL=http://127.0.0.1:8545

# Optional. Used by scripts/deployKernel.ts.
# Defaults to ../kernel/matcher.polkavm relative to the contracts directory.
KERNEL_BYTECODE_PATH=../kernel/matcher.polkavm
